  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#ff660018", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#00dd77" }
    },
    {
      "name": "String escapes",
      "scope": "constant.character.escape",
      "settings": { "foreground": "#00ff88" }
    },
    {
      "name": "Template expression",
      "scope": ["string.template punctuation.definition.template-expression", "string.template variable.other.template-expression"],
      "settings": { "foreground": "#ff8800" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric", "constant.numeric.integer", "constant.numeric.float"],
      "settings": { "foreground": "#ff8800" }
    },
    {
      "name": "Boolean and null",
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#ff4400", "fontStyle": "italic" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "keyword.control", "keyword.operator.new", "keyword.other"],
      "settings": { "foreground": "#ff3355", "fontStyle": "" }
    },
    {
      "name": "Storage keywords",
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#ff5500" }
    },
    {
      "name": "Imports and exports",
      "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from", "keyword.control.as"],
      "settings": { "foreground": "#ff3355" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "keyword.operator.assignment", "keyword.operator.comparison", "keyword.operator.logical", "keyword.operator.arithmetic"],
      "settings": { "foreground": "#ff6600" }
    },
    {
      "name": "Function names",
      "scope": ["entity.name.function", "meta.function entity.name.function"],
      "settings": { "foreground": "#ffaa00" }
    },
    {
      "name": "Function calls",
      "scope": ["meta.function-call entity.name.function", "support.function"],
      "settings": { "foreground": "#ff8800" }
    },
    {
      "name": "Function parameters",
      "scope": ["variable.parameter", "meta.function.parameters variable"],
      "settings": { "foreground": "#d0a080" }
    },
    {
      "name": "Class names",
      "scope": ["entity.name.class", "entity.name.type.class"],
      "settings": { "foreground": "#ffcc00" }
    },
    {
      "name": "Inherited class",
      "scope": "entity.other.inherited-class",
      "settings": { "foreground": "#ffaa00", "fontStyle": "italic" }
    },
    {
      "name": "Interface names",
      "scope": ["entity.name.interface", "entity.name.type.interface"],
      "settings": { "foreground": "#00ccff" }
    },
    {
      "name": "Type names",
      "scope": ["entity.name.type", "support.type"],
      "settings": { "foreground": "#00aadd" }
    },
    {
      "name": "Decorators / Annotations",
      "scope": ["meta.decorator", "entity.name.tag.css"],
      "settings": { "foreground": "#cc44ff" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other.readwrite"],
      "settings": { "foreground": "#e0d0ff" }
    },
    {
      "name": "Constants",
      "scope": ["variable.other.constant", "entity.name.constant"],
      "settings": { "foreground": "#ff8800" }
    },
    {
      "name": "Object properties",
      "scope": ["variable.other.property", "meta.object-literal.key"],
      "settings": { "foreground": "#ddaa88" }
    },
    {
      "name": "Object keys",
      "scope": "support.type.property-name",
      "settings": { "foreground": "#d0a080" }
    },
    {
      "name": "this / self",
      "scope": ["variable.language.this", "variable.language.self"],
      "settings": { "foreground": "#ff5500", "fontStyle": "italic" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#3a3a5a" }
    },
    {
      "name": "Brackets",
      "scope": ["punctuation.definition.parameters", "punctuation.definition.block", "meta.brace"],
      "settings": { "foreground": "#ff660055"}
    },
    {
      "name": "HTML tags",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": { "foreground": "#ff5500" }
    },
    {
      "name": "HTML attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#ffaa00" }
    },
    {
      "name": "CSS selectors",
      "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#ff6600" }
    },
    {
      "name": "CSS properties",
      "scope": ["support.type.property-name.css", "meta.property-name"],
      "settings": { "foreground": "#ddaa00" }
    },
    {
      "name": "CSS values",
      "scope": ["meta.property-value", "support.constant.property-value"],
      "settings": { "foreground": "#00cc77" }
    },
    {
      "name": "CSS units",
      "scope": "keyword.other.unit",
      "settings": { "foreground": "#ff8800" }
    },
    {
      "name": "CSS colors",
      "scope": "constant.other.color",
      "settings": { "foreground": "#00ff88" }
    },
    {
      "name": "JSON keys",
      "scope": "support.type.property-name.json",
      "settings": { "foreground": "#ff8800" }
    },
    {
      "name": "JSON string values",
      "scope": "string.quoted.double.json",
      "settings": { "foreground": "#00cc77" }
    },
    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#ff6600", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": "markup.bold",
      "settings": { "foreground": "#ffaa00", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": "markup.italic",
      "settings": { "foreground": "#dd8800", "fontStyle": "italic" }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.raw.inline", "markup.fenced_code"],
      "settings": { "foreground": "#00cc77" }
    },
    {
      "name": "Markdown links",
      "scope": "markup.underline.link",
      "settings": { "foreground": "#00ccff" }
    },
    {
      "name": "Markdown blockquote",
      "scope": "markup.quote",
      "settings": { "foreground": "#664422", "fontStyle": "italic" }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp", "constant.regexp"],
      "settings": { "foreground": "#ff4488" }
    },
    {
      "name": "Invalid",
      "scope": "invalid",
      "settings": { "foreground": "#ff2244", "fontStyle": "underline" }
    },
    {
      "name": "Deprecated",
      "scope": "invalid.deprecated",
      "settings": { "foreground": "#ff8800", "fontStyle": "italic underline" }
    }
  ],
  
}
